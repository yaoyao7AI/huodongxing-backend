# 复制为 .env 后填入真实值（启动时由 loadEnv.js 自动加载）
# 注意：如果 shell 里已 export 同名变量，这里不会覆盖（以 shell 为准）

DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=huodongxing_db
DB_CONNECTION_LIMIT=10

HOST=127.0.0.1
PORT=3001

AUTH_SECRET=change_me_in_prod
AUTH_TOKEN_TTL_SECONDS=604800

# 与 life-design-backend 共享的换票密钥（两端必须完全一致）
EVENTS_EXCHANGE_SECRET=change_me_shared_exchange_secret
# huodongxing-backend 自签 Events Token 密钥
EVENTS_JWT_SECRET=change_me_events_jwt_secret
EVENTS_TOKEN_TTL_SECONDS=1800
